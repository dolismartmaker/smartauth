{
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": "^5.0",
        "paragonie/sodium_compat": "^1.20"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "symfony/http-client": "^5.4 || ^6.4 || ^7.4"
    },
    "suggest": {
        "cap-rel/dolibarr-integration-sqlite": "For integration tests with real Dolibarr (requires PHP 8.2+)",
        "symfony/http-client": "For HTTP functional tests"
    },
    "autoload": {
        "psr-4": {
            "SmartAuth\\Api\\": "api/",
            "SmartAuth\\DolibarrMapping\\": "dolMapping/"
        },
        "classmap": [
            "class/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "SmartAuth\\Tests\\": "test/phpunit/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "php -d pcov.enabled=1 -d pcov.directory=. vendor/bin/phpunit -c phpunit-integration.xml",
        "test:integration-dolibarr": "php -d pcov.enabled=1 -d pcov.directory=. vendor/bin/phpunit -c phpunit-integration-dolibarr.xml",
        "test:coverage": "php -d pcov.enabled=1 -d pcov.directory=. vendor/bin/phpunit",
        "test:http": "phpunit -c phpunit-http.xml"
    }
}
